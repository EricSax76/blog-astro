---
interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;

const baseLinkClass = mobile
  ? "text-deep-green font-medium"
  : "text-deep-green hover:text-sage font-medium text-sm transition-colors";

const registerClass = mobile
  ? "px-8 py-3 rounded-full bg-deep-green text-cream font-bold shadow-lg"
  : "px-5 py-2 rounded-full bg-sage/20 text-deep-green font-semibold text-sm hover:bg-sage/30 transition-all duration-200";
---

{
  mobile ? (
    <>
      <hr id="mobile-auth-hr" class="w-20 border-sage/30" />
      <a href="/publicar" class={baseLinkClass}>Escribir</a>
      <a id="mobile-my-posts" href="/mis-publicaciones" class={`${baseLinkClass} hidden`}>
        Mis publicaciones
      </a>
      <a id="mobile-login" href="/acceder" class={baseLinkClass}>Acceder</a>
      <a id="mobile-register" href="/registrate" class={registerClass}>
        Regístrate
      </a>
      <div
        id="mobile-profile-menu"
        class="hidden w-full max-w-xs rounded-2xl border border-sage/25 bg-white/80 p-4 text-center shadow-sm"
      >
        <p
          class="text-xs uppercase tracking-[0.18em] text-deep-green/55 font-semibold"
        >
          Perfil
        </p>
        <p
          id="mobile-profile-email"
          class="mt-2 truncate text-sm text-deep-green/75"
          title="Usuario autenticado"
        ></p>
        <div class="mt-4 flex flex-col gap-2">
          <a
            href="/mi-perfil"
            class="rounded-full border border-sage/35 px-4 py-2 text-sm font-semibold text-deep-green hover:bg-sage/10 transition-colors"
          >
            Mi perfil
          </a>
          <button
            type="button"
            disabled
            class="rounded-full border border-sage/25 px-4 py-2 text-sm font-semibold text-deep-green/45 cursor-not-allowed"
            title="Disponible próximamente"
          >
            Ajustes
          </button>
          <button
            id="mobile-logout-button"
            type="button"
            class="rounded-full bg-deep-green px-4 py-2 text-sm font-semibold text-cream hover:bg-deep-green/90 transition-colors"
          >
            Cerrar sesión
          </button>
        </div>
      </div>
    </>
  ) : (
    <div
      id="auth-buttons"
      class="flex items-center gap-3 pl-4 border-l border-sage/30"
    >
      <a href="/publicar" class={baseLinkClass}>Escribir</a>
      <a
        id="desktop-my-posts"
        href="/mis-publicaciones"
        class={`${baseLinkClass} hidden`}
      >
        Mis publicaciones
      </a>
      <a id="desktop-login" href="/acceder" class={baseLinkClass}>Acceder</a>
      <a id="desktop-register" href="/registrate" class={registerClass}>
        Regístrate
      </a>
      <div id="desktop-profile-menu" class="relative hidden">
        <button
          id="desktop-profile-button"
          type="button"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="desktop-profile-dropdown"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-sage/35 bg-white/70 text-deep-green shadow-sm transition-colors hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-sage focus-visible:ring-offset-2"
        >
          <span
            id="desktop-profile-avatar-fallback"
            class="flex h-8 w-8 items-center justify-center rounded-full bg-deep-green/15 text-xs font-bold uppercase text-deep-green"
            >U</span
          >
          <img
            id="desktop-profile-avatar-image"
            class="hidden h-8 w-8 rounded-full object-cover"
            alt="Avatar de perfil"
          />
        </button>
        <div
          id="desktop-profile-dropdown"
          role="menu"
          aria-labelledby="desktop-profile-button"
          class="hidden absolute right-0 top-[calc(100%+0.6rem)] min-w-[210px] rounded-2xl border border-sage/25 bg-white p-2 shadow-xl"
        >
          <p
            id="desktop-profile-email"
            class="mb-1 truncate rounded-xl bg-cream/70 px-3 py-2 text-xs font-semibold text-deep-green/70"
            title="Usuario autenticado"
          ></p>
          <a
            href="/mi-perfil"
            role="menuitem"
            class="block rounded-xl px-3 py-2 text-sm font-medium text-deep-green hover:bg-cream transition-colors"
          >
            Mi perfil
          </a>
          <button
            type="button"
            role="menuitem"
            disabled
            class="block w-full rounded-xl px-3 py-2 text-left text-sm font-medium text-deep-green/45 cursor-not-allowed"
            title="Disponible próximamente"
          >
            Ajustes
          </button>
          <hr class="my-1 border-sage/20" />
          <button
            id="desktop-logout-button"
            type="button"
            role="menuitem"
            class="block w-full rounded-xl px-3 py-2 text-left text-sm font-semibold text-deep-green hover:bg-cream transition-colors"
          >
            Cerrar sesión
          </button>
        </div>
      </div>
    </div>
  )
}
