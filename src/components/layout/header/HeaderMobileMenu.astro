---
import HeaderAuthActions from "./HeaderAuthActions.astro";
import HeaderPrimaryLinks from "./HeaderPrimaryLinks.astro";
---

<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
  class="fixed inset-0 bg-cream z-40 flex flex-col justify-center items-center opacity-0 pointer-events-none transition-all duration-300"
>
  <nav class="flex flex-col items-center gap-6 text-xl">
    <HeaderPrimaryLinks mobile />
    <HeaderAuthActions mobile />
  </nav>
</div>
