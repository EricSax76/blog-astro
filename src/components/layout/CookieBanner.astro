---
// CookieBanner.astro
// Banner de consentimiento de cookies conforme a LOPDGDD / RGPD.
// Se muestra automáticamente si el usuario no ha tomado ninguna decisión previa.
---

<!-- Banner principal (aviso simplificado) -->
<div
  id="cookie-banner"
  role="dialog"
  aria-modal="false"
  aria-label="Aviso de cookies"
  class="fixed bottom-0 left-0 right-0 z-[9999] transform translate-y-full transition-transform duration-500 ease-out"
>
  <div class="bg-deep-green text-cream shadow-2xl border-t border-sage/20 px-6 py-5 md:px-10">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
      <div class="flex-1 space-y-1">
        <p class="font-sans font-semibold text-sm">Este sitio utiliza cookies y tecnologías similares</p>
        <p class="text-cream/70 text-xs leading-relaxed">
          Las cookies necesarias se usan para la autenticación y el funcionamiento del sitio.
          Puedes aceptar todas, solo las necesarias o personalizar tus preferencias.
          Más información en nuestra
          <a href="/cookies" class="text-sage hover:text-white underline transition-colors">Política de Cookies</a>.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 shrink-0">
        <button
          id="cookie-reject-all"
          class="rounded-full border border-cream/30 px-4 py-2 text-xs font-semibold text-cream/80 hover:bg-cream/10 transition-colors"
        >
          Solo necesarias
        </button>
        <button
          id="cookie-customize"
          class="rounded-full border border-sage/60 px-4 py-2 text-xs font-semibold text-sage hover:bg-sage/10 transition-colors"
        >
          Personalizar
        </button>
        <button
          id="cookie-accept-all"
          class="rounded-full bg-sage px-5 py-2 text-xs font-semibold text-white hover:bg-sage/80 transition-colors"
        >
          Aceptar todas
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal de preferencias granulares -->
<div
  id="cookie-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Preferencias de cookies"
  class="fixed inset-0 z-[10000] hidden items-center justify-center p-4"
>
  <!-- Fondo oscuro -->
  <div id="cookie-modal-overlay" class="absolute inset-0 bg-deep-green/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative bg-cream rounded-3xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="p-6 md:p-8 space-y-6">
      <div class="space-y-1">
        <h2 class="font-serif text-2xl font-bold text-deep-green">Preferencias de cookies</h2>
        <p class="text-sm text-deep-green/70 leading-relaxed">
          Selecciona qué categorías de cookies deseas permitir. Las necesarias siempre están
          activas porque son imprescindibles para el funcionamiento del sitio.
        </p>
      </div>

      <div class="space-y-4">

        <!-- Necesarias (siempre activas) -->
        <div class="flex items-start justify-between gap-4 p-4 rounded-2xl bg-deep-green/5 border border-sage/10">
          <div class="flex-1 space-y-1">
            <p class="font-semibold text-sm text-deep-green">Necesarias</p>
            <p class="text-xs text-deep-green/60 leading-relaxed">
              Autenticación de usuario y funcionamiento básico del sitio.
              No pueden desactivarse.
            </p>
          </div>
          <div class="shrink-0 flex items-center">
            <span class="text-xs text-sage font-semibold">Siempre activas</span>
          </div>
        </div>

        <!-- Funcionales -->
        <div class="flex items-start justify-between gap-4 p-4 rounded-2xl bg-deep-green/5 border border-sage/10">
          <div class="flex-1 space-y-1">
            <label for="consent-functional" class="font-semibold text-sm text-deep-green cursor-pointer">
              Funcionales
            </label>
            <p class="text-xs text-deep-green/60 leading-relaxed">
              Preferencias personalizadas como idioma o configuración de visualización.
            </p>
          </div>
          <div class="shrink-0">
            <input
              type="checkbox"
              id="consent-functional"
              name="functional"
              class="cookie-toggle w-5 h-5 rounded accent-sage cursor-pointer"
            />
          </div>
        </div>

        <!-- Analíticas -->
        <div class="flex items-start justify-between gap-4 p-4 rounded-2xl bg-deep-green/5 border border-sage/10">
          <div class="flex-1 space-y-1">
            <label for="consent-analytics" class="font-semibold text-sm text-deep-green cursor-pointer">
              Analíticas
            </label>
            <p class="text-xs text-deep-green/60 leading-relaxed">
              Estadísticas de uso para mejorar la experiencia del sitio.
              Actualmente no están activas.
            </p>
          </div>
          <div class="shrink-0">
            <input
              type="checkbox"
              id="consent-analytics"
              name="analytics"
              class="cookie-toggle w-5 h-5 rounded accent-sage cursor-pointer"
            />
          </div>
        </div>

        <!-- Marketing -->
        <div class="flex items-start justify-between gap-4 p-4 rounded-2xl bg-deep-green/5 border border-sage/10">
          <div class="flex-1 space-y-1">
            <label for="consent-marketing" class="font-semibold text-sm text-deep-green cursor-pointer">
              Marketing
            </label>
            <p class="text-xs text-deep-green/60 leading-relaxed">
              Personalización de contenido y publicidad. Actualmente no están activas.
            </p>
          </div>
          <div class="shrink-0">
            <input
              type="checkbox"
              id="consent-marketing"
              name="marketing"
              class="cookie-toggle w-5 h-5 rounded accent-sage cursor-pointer"
            />
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 pt-2">
        <button
          id="cookie-save-preferences"
          class="flex-1 rounded-full bg-deep-green px-5 py-3 text-sm font-semibold text-cream hover:bg-deep-green/90 transition-colors"
        >
          Guardar preferencias
        </button>
        <button
          id="cookie-modal-accept-all"
          class="flex-1 rounded-full bg-sage px-5 py-3 text-sm font-semibold text-white hover:bg-sage/80 transition-colors"
        >
          Aceptar todas
        </button>
      </div>

      <p class="text-xs text-deep-green/50 text-center">
        <a href="/cookies" class="hover:text-sage transition-colors underline">Política de Cookies</a>
        ·
        <a href="/privacidad" class="hover:text-sage transition-colors underline">Política de Privacidad</a>
      </p>
    </div>
  </div>
</div>

<script>
  import {
    hasConsented,
    acceptAll,
    rejectAll,
    saveConsent,
    getConsent,
  } from "../../scripts/ux/cookie-consent.js";

  const banner = document.getElementById("cookie-banner");
  const modal = document.getElementById("cookie-modal");
  const overlay = document.getElementById("cookie-modal-overlay");

  // --- Banner ---

  function showBanner() {
    banner?.classList.remove("translate-y-full");
    banner?.classList.add("translate-y-0");
  }

  function hideBanner() {
    banner?.classList.add("translate-y-full");
    banner?.classList.remove("translate-y-0");
  }

  // --- Modal ---

  function showModal() {
    if (!modal) return;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    // Precargar valores guardados
    const consent = getConsent();
    const functional = document.getElementById("consent-functional") as HTMLInputElement | null;
    const analytics = document.getElementById("consent-analytics") as HTMLInputElement | null;
    const marketing = document.getElementById("consent-marketing") as HTMLInputElement | null;
    if (functional) functional.checked = consent?.functional ?? false;
    if (analytics) analytics.checked = consent?.analytics ?? false;
    if (marketing) marketing.checked = consent?.marketing ?? false;
  }

  function hideModal() {
    if (!modal) return;
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  // --- Init ---

  if (!hasConsented()) {
    // Pequeño retraso para que no interrumpa el renderizado inicial
    setTimeout(showBanner, 800);
  }

  // Escuchar evento de apertura desde otras páginas (ej: /cookies)
  window.addEventListener("open-cookie-banner", () => {
    showModal();
  });

  // --- Botones del banner ---

  document.getElementById("cookie-accept-all")?.addEventListener("click", () => {
    acceptAll();
    hideBanner();
  });

  document.getElementById("cookie-reject-all")?.addEventListener("click", () => {
    rejectAll();
    hideBanner();
  });

  document.getElementById("cookie-customize")?.addEventListener("click", () => {
    showModal();
    hideBanner();
  });

  // --- Botones del modal ---

  document.getElementById("cookie-modal-accept-all")?.addEventListener("click", () => {
    acceptAll();
    hideModal();
    hideBanner();
  });

  document.getElementById("cookie-save-preferences")?.addEventListener("click", () => {
    const functional = (document.getElementById("consent-functional") as HTMLInputElement)?.checked ?? false;
    const analytics = (document.getElementById("consent-analytics") as HTMLInputElement)?.checked ?? false;
    const marketing = (document.getElementById("consent-marketing") as HTMLInputElement)?.checked ?? false;
    saveConsent({ functional, analytics, marketing });
    hideModal();
    hideBanner();
  });

  overlay?.addEventListener("click", () => {
    hideModal();
    // Si no ha tomado decisión, volver a mostrar el banner
    if (!hasConsented()) showBanner();
  });
</script>
