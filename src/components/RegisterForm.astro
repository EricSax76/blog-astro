<section id="registro" class="space-y-4">
  <h4 class="font-serif text-2xl font-semibold text-deep-green">Crear cuenta</h4>
  <form id="register-form" class="space-y-4">
    <label class="block space-y-2">
      <span
        class="text-xs uppercase tracking-[0.2em] text-deep-green/60 font-semibold"
      >
        Nombre
      </span>
      <input
        type="text"
        name="name"
        autocomplete="name"
        placeholder="Tu nombre"
        class="w-full rounded-2xl border border-sage/30 bg-cream/60 px-4 py-3 text-deep-green placeholder:text-deep-green/40 focus:outline-none focus:ring-2 focus:ring-sage/40"
      />
    </label>

    <label class="block space-y-2">
      <span
        class="text-xs uppercase tracking-[0.2em] text-deep-green/60 font-semibold"
      >
        Correo
      </span>
      <input
        type="email"
        name="email"
        autocomplete="email"
        required
        placeholder="nombre@correo.com"
        class="w-full rounded-2xl border border-sage/30 bg-cream/60 px-4 py-3 text-deep-green placeholder:text-deep-green/40 focus:outline-none focus:ring-2 focus:ring-sage/40"
      />
    </label>

    <label class="block space-y-2">
      <span
        class="text-xs uppercase tracking-[0.2em] text-deep-green/60 font-semibold"
      >
        Contraseña
      </span>
      <input
        type="password"
        name="password"
        autocomplete="new-password"
        minlength="6"
        required
        placeholder="Mínimo 6 caracteres"
        class="w-full rounded-2xl border border-sage/30 bg-cream/60 px-4 py-3 text-deep-green placeholder:text-deep-green/40 focus:outline-none focus:ring-2 focus:ring-sage/40"
      />
    </label>

    <label class="block space-y-2">
      <span
        class="text-xs uppercase tracking-[0.2em] text-deep-green/60 font-semibold"
      >
        Confirmar contraseña
      </span>
      <input
        type="password"
        name="confirmPassword"
        autocomplete="new-password"
        minlength="6"
        required
        placeholder="Repite la contraseña"
        class="w-full rounded-2xl border border-sage/30 bg-cream/60 px-4 py-3 text-deep-green placeholder:text-deep-green/40 focus:outline-none focus:ring-2 focus:ring-sage/40"
      />
    </label>

    <!-- Consentimiento RGPD -->
    <div class="space-y-3 pt-2 border-t border-sage/20">
      <label class="flex items-start gap-3 cursor-pointer group">
        <input
          type="checkbox"
          name="consent-privacy"
          id="consent-privacy"
          required
          class="mt-0.5 w-4 h-4 rounded accent-sage shrink-0 cursor-pointer"
        />
        <span class="text-xs text-deep-green/70 leading-relaxed">
          He leído y acepto la
          <a
            href="/privacidad"
            target="_blank"
            class="text-sage hover:underline font-medium"
          >Política de Privacidad</a>
          y el
          <a
            href="/aviso-legal"
            target="_blank"
            class="text-sage hover:underline font-medium"
          >Aviso Legal</a>.
          El tratamiento de mis datos se realizará conforme al RGPD y la LOPDGDD.
          <span class="text-deep-green font-semibold"> *</span>
        </span>
      </label>

      <label class="flex items-start gap-3 cursor-pointer group">
        <input
          type="checkbox"
          name="consent-age"
          id="consent-age"
          required
          class="mt-0.5 w-4 h-4 rounded accent-sage shrink-0 cursor-pointer"
        />
        <span class="text-xs text-deep-green/70 leading-relaxed">
          Confirmo que soy mayor de 14 años o cuento con el consentimiento de mis
          padres o tutores legales (art. 7 LOPDGDD).
          <span class="text-deep-green font-semibold"> *</span>
        </span>
      </label>

      <label class="flex items-start gap-3 cursor-pointer group">
        <input
          type="checkbox"
          name="consent-communications"
          id="consent-communications"
          class="mt-0.5 w-4 h-4 rounded accent-sage shrink-0 cursor-pointer"
        />
        <span class="text-xs text-deep-green/70 leading-relaxed">
          Acepto recibir comunicaciones informativas sobre novedades del blog
          <em>(opcional)</em>.
        </span>
      </label>

      <p class="text-xs text-deep-green/40">
        * Campos obligatorios. Puedes ejercer tus derechos RGPD en
        <a href="mailto:info@elalmadelasflores.com" class="text-sage hover:underline">
          info@elalmadelasflores.com
        </a>.
      </p>
    </div>

    <button
      type="submit"
      class="w-full rounded-full bg-deep-green px-6 py-3 text-cream font-semibold shadow-lg shadow-sage/20 hover:bg-deep-green/90 transition-colors"
    >
      Registrarme
    </button>
  </form>
</section>
