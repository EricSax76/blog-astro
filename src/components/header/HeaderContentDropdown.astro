---
import { ARCHIVE_YEARS } from "./config";
---

<div class="relative group">
  <button
    id="contenido-btn"
    class="flex items-center gap-1 text-deep-green hover:text-sage font-medium text-sm lg:text-base transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-sage focus-visible:ring-offset-2 rounded"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls="contenido-dropdown"
  >
    Contenido
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-4 w-4 opacity-70 group-hover:rotate-180 aria-expanded:rotate-180 transition-transform duration-200"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      aria-hidden="true"
      focusable="false"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>
  <div
    id="contenido-dropdown"
    role="menu"
    aria-labelledby="contenido-btn"
    class="absolute right-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0 group-focus-within:translate-y-0"
  >
    <div
      class="bg-white rounded-xl shadow-xl border border-sage/20 p-2 min-w-[160px] flex flex-col gap-1"
    >
      {
        ARCHIVE_YEARS.map((year) => (
          <a
            href={`/archivo/${year}`}
            role="menuitem"
            tabindex="-1"
            class="block px-4 py-2 text-sm text-deep-green hover:bg-cream rounded-lg transition-colors focus:outline-none focus-visible:bg-cream focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-sage"
          >
            Archivo {year}
          </a>
        ))
      }
    </div>
  </div>
</div>
