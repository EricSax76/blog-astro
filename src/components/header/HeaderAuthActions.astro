---
interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;

const baseLinkClass = mobile
  ? "text-deep-green font-medium"
  : "text-deep-green hover:text-sage font-medium text-sm transition-colors";

const registerClass = mobile
  ? "px-8 py-3 rounded-full bg-deep-green text-cream font-bold shadow-lg"
  : "px-5 py-2 rounded-full bg-sage/20 text-deep-green font-semibold text-sm hover:bg-sage/30 transition-all duration-200";
---

{
  mobile ? (
    <>
      <hr id="mobile-auth-hr" class="w-20 border-sage/30" />
      <a href="/publicar" class={baseLinkClass}>Escribir</a>
      <a id="mobile-login" href="/acceder" class={baseLinkClass}>Acceder</a>
      <a id="mobile-register" href="/registrate" class={registerClass}>
        Regístrate
      </a>
    </>
  ) : (
    <div
      id="auth-buttons"
      class="flex items-center gap-3 pl-4 border-l border-sage/30"
    >
      <a href="/publicar" class={baseLinkClass}>Escribir</a>
      <a id="desktop-login" href="/acceder" class={baseLinkClass}>Acceder</a>
      <a id="desktop-register" href="/registrate" class={registerClass}>
        Regístrate
      </a>
    </div>
  )
}
