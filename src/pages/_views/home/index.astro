---
import HomeAuthorsAccess from "../../../components/home/HomeAuthorsAccess.astro";
import HomeContentMap from "../../../components/home/HomeContentMap.astro";
import HomeFeaturedFlowers from "../../../components/home/HomeFeaturedFlowers.astro";
import HomeHero from "../../../components/home/HomeHero.astro";
import HomePrinciplesTimeline from "../../../components/home/HomePrinciplesTimeline.astro";
import {
  HOME_CONTENT_SECTIONS,
  HOME_FEATURED_FLOWERS,
  HOME_PRINCIPLES,
  HOME_TIMELINE,
  NEWEST_ARCHIVE_YEAR,
} from "../../../data/home-page";
import Layout from "../../../layouts/Layout.astro";
---

<Layout
  title="El Alma de las Flores | Flores de Bach, historia y comunidad"
  description="Explora las 38 flores de Bach, la biografía de Edward Bach y el anuario del blog. Fichas completas con estado emocional, transformación positiva y afirmación."
>
  <HomeHero newestArchiveYear={NEWEST_ARCHIVE_YEAR} />
  <HomeContentMap sections={HOME_CONTENT_SECTIONS} />
  <HomePrinciplesTimeline
    principles={HOME_PRINCIPLES}
    timeline={HOME_TIMELINE}
  />
  <HomeFeaturedFlowers featuredFlowers={HOME_FEATURED_FLOWERS} />
  <HomeAuthorsAccess newestArchiveYear={NEWEST_ARCHIVE_YEAR} />
</Layout>
