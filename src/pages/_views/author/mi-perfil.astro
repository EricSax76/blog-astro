---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Mi perfil | El Alma de las Flores">
  <section class="mx-auto max-w-5xl space-y-4 text-center">
    <p
      class="inline-flex items-center rounded-full border border-sage/30 bg-white/70 px-4 py-2 text-xs font-semibold uppercase tracking-[0.32em] text-deep-green/60 shadow-sm"
    >
      Perfil de autor
    </p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-deep-green">
      Mi perfil
    </h1>
    <p class="text-deep-green/70 text-lg max-w-3xl mx-auto">
      Gestiona tus datos de cuenta, actualiza tu foto y guarda tus cambios.
    </p>
  </section>

  <section class="mt-10 max-w-4xl mx-auto">
    <article
      class="bg-white/90 border border-sage/20 rounded-[2rem] shadow-xl shadow-sage/5 p-6 md:p-8 space-y-6"
    >
      <p
        id="profile-config-warning"
        class="hidden rounded-2xl border border-amber-300/60 bg-amber-50 px-4 py-3 text-sm text-amber-800"
      >
        Falta configurar Firebase en variables `PUBLIC_FIREBASE_*`.
      </p>

      <p
        id="profile-message"
        class="hidden rounded-2xl border px-4 py-3 text-sm"
        aria-live="polite"
      ></p>

      <form id="profile-form" class="space-y-6">
        <div class="rounded-2xl border border-sage/25 bg-cream/70 p-4 sm:p-5">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
            <div
              id="profile-avatar-fallback"
              class="flex h-20 w-20 items-center justify-center rounded-full bg-deep-green/15 text-2xl font-bold uppercase text-deep-green"
            >
              U
            </div>
            <img
              id="profile-avatar-preview"
              class="hidden h-20 w-20 rounded-full border border-sage/30 object-cover"
              alt="Avatar de perfil"
            />

            <div class="flex-1 space-y-3">
              <div>
                <p
                  class="text-xs uppercase tracking-[0.2em] text-deep-green/60 font-semibold"
                >
                  Foto de perfil
                </p>
                <p class="mt-1 text-sm text-deep-green/68">
                  Sube una imagen cuadrada para el avatar del appbar.
                </p>
              </div>
              <input
                id="profile-photo"
                type="file"
                accept="image/*"
                class="block w-full cursor-pointer rounded-2xl border border-dashed border-sage/35 bg-white/70 px-4 py-3 text-sm text-deep-green file:mr-4 file:rounded-full file:border-0 file:bg-sage/20 file:px-4 file:py-2 file:font-semibold file:text-deep-green hover:file:bg-sage/30"
              />
            </div>
          </div>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          <label class="block space-y-2 md:col-span-1">
            <span
              class="text-xs uppercase tracking-[0.2em] text-deep-green/60 font-semibold"
            >
              Nombre visible
            </span>
            <input
              id="profile-display-name"
              type="text"
              maxlength="50"
              placeholder="Tu nombre público"
              class="min-h-[48px] w-full rounded-2xl border border-sage/30 bg-cream/60 px-4 py-3 text-base text-deep-green placeholder:text-deep-green/40 focus:outline-none focus:ring-2 focus:ring-sage/40"
            />
          </label>

          <label class="block space-y-2 md:col-span-1">
            <span
              class="text-xs uppercase tracking-[0.2em] text-deep-green/60 font-semibold"
            >
              Correo
            </span>
            <input
              id="profile-email"
              type="email"
              readonly
              disabled
              class="min-h-[48px] w-full rounded-2xl border border-sage/30 bg-cream/45 px-4 py-3 text-base text-deep-green/70"
            />
          </label>
        </div>

        <div class="grid gap-3 rounded-2xl border border-sage/20 bg-sage/5 p-4 text-sm text-deep-green/75 sm:grid-cols-2">
          <p>Rol: <strong id="profile-role">—</strong></p>
          <p>Miembro desde: <strong id="profile-created-at">—</strong></p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <button
            id="profile-save-button"
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-full bg-deep-green px-6 py-3 font-semibold text-cream shadow-lg shadow-sage/20 transition-transform hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
          >
            Guardar cambios
          </button>
          <a
            href="/mis-publicaciones"
            class="inline-flex w-full items-center justify-center rounded-full border border-sage/40 px-6 py-3 font-semibold text-deep-green hover:bg-sage/10 transition-colors sm:w-auto"
          >
            Mis publicaciones
          </a>
          <a
            href="/publicar"
            class="inline-flex w-full items-center justify-center rounded-full border border-sage/40 px-6 py-3 font-semibold text-deep-green hover:bg-sage/10 transition-colors sm:w-auto"
          >
            Ir a escribir
          </a>
        </div>
      </form>
    </article>
  </section>
</Layout>

<script src="../../../scripts/profile/settings.js"></script>
