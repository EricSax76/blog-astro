# Configuración del SDK web de Firebase (cliente).
# Cópialo a .env y rellena los valores desde:
# Firebase Console > Project settings > Your apps > SDK setup and configuration.
# El prefijo PUBLIC_ los expone al navegador (necesario para el SDK cliente);
# no incluyas aquí secretos de servidor ni claves de service account.

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
