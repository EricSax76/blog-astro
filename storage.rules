rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isValidAvatarUpload() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Imagenes publicadas del blog:
    // path esperado: blog/posts/{uid}/{archivo}
    // lectura publica, escritura solo por el propietario autenticado.
    match /blog/posts/{uid}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isOwner(uid) && isValidImageUpload();
      allow delete: if isOwner(uid);
    }

    // Avatar de perfil por usuario:
    // path esperado: users/{uid}/avatar/{archivo}
    // El avatar es identidad publica del autor (se muestra en header y comentarios),
    // por eso lectura publica; escritura solo del propietario.
    match /users/{uid}/avatar/{allPaths=**} {
      allow read: if true;
      allow create, update: if isOwner(uid) && isValidAvatarUpload();
      allow delete: if isOwner(uid);
    }

    // Resto de archivos privados por usuario:
    // por defecto solo lectura del propietario, escritura denegada.
    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
