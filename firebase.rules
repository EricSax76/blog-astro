rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidDisplayName() {
      return !request.resource.data.keys().hasAny(["displayName"])
        || (request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 50);
    }

    function isValidPhotoURL() {
      return !request.resource.data.keys().hasAny(["photoURL"])
        || (request.resource.data.photoURL is string
          && request.resource.data.photoURL.size() <= 2048);
    }

    function isAllowedUserProfilePatch() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "displayName",
          "photoURL",
          "updatedAt",
          "lastSeenAt"
        ])
        && isValidDisplayName()
        && isValidPhotoURL();
    }

    function isPostOwner() {
      return isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    function isCreatingOwnPost() {
      return isSignedIn() && request.resource.data.authorUid == request.auth.uid;
    }

    // Lectura pública del blog. Escritura solo del autor dueño del post.
    match /posts/{postId} {
      allow read: if true;
      allow create: if isCreatingOwnPost();
      allow update: if isPostOwner()
        && request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isPostOwner();
    }

    // Perfil privado por usuario:
    // - lectura: solo el propio usuario
    // - actualización: solo campos de perfil editables por cliente
    // - creación/borrado: solo backend (Cloud Functions admin)
    match /users/{userId} {
      allow read: if isOwnUser(userId);
      allow update: if isOwnUser(userId) && isAllowedUserProfilePatch();
      allow create, delete: if false;
    }

    // Social Interactions: Likes
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Social Interactions: Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Deniega por defecto cualquier otra colección.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
